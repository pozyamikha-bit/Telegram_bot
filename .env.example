# Скопируйте этот файл в .env и заполните своими значениями.
# Файл .env никогда никому не показывайте и не выкладывайте в открытый доступ.

# Токен, полученный от @BotFather
BOT_TOKEN=вставьте_сюда_токен

# ID Google-таблицы (кусок ссылки между /d/ и /edit)
GOOGLE_SHEET_ID=вставьте_сюда_id_таблицы

# Имя файла с ключом сервисного аккаунта Google (лежит рядом с bot.py)
GOOGLE_CREDENTIALS_FILE=service_account.json

# Названия вкладок (листов) внутри таблицы
GOOGLE_SHEET_WORKSHEET_REG=Регистрация
GOOGLE_SHEET_WORKSHEET_RECEIPTS=Чеки
GOOGLE_SHEET_WORKSHEET_MODERATORS=Модераторы

# Telegram ID ВЛАДЕЛЬЦЕВ бота (не рядовых модераторов - тех можно добавлять
# прямо из бота), через запятую, без пробелов внутри чисел.
# Свой ID узнайте, написав любому боту-помощнику, например @userinfobot —
# он в ответ пришлёт число вида 123456789.
ADMIN_IDS=вставьте_сюда_id_через_запятую
